# Root environment template (local dev / CI helpers)
# Copy to .env and fill in values. NEVER commit real secrets.

# ── track-api ─────────────────────────────────────────────────────────────────
PORT=8080
MONGO_URL=mongodb://localhost:27017/tortoise-gps
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change_me_in_production
CORS_ORIGINS=http://localhost:3000
DEFAULT_COMPANY_NAME=Default Company
DEFAULT_COMPANY_SLUG=default-company
FORCE_SINGLE_COMPANY=false
SIM_TRACK_CLEANUP_ENABLED=true
SIM_TRACK_SERIALS=9900111001,9900111002,9900111003,9900111004,9900111005,9900111006,9900111007,9900111008,9900111009,9900111010,9900111011,9900111012,9900111013,9900111014,9900111015,9900111016,9900111017,9900111018,9900111019,9900111020,9900111021,9900111022,9900111023,9900111024,9900111025,9900111026,9900111027,9900111028,9900111029,9900111030
# Optional for storage/repack migrations:
# MIGRATION_KEEP_TRACKS_BACKUP=true

# ── tests (track-api / track-data) ────────────────────────────────────────────
MONGO_URL_LOGIC_TEST=mongodb://localhost:27017/track-api-test
MONGO_URL_USER_DATA_TEST=mongodb://localhost:27017/track-api-user-data-test

# ── e2e seed defaults ──────────────────────────────────────────────────────────
E2E_COMPANY_SLUG=e2e-company
E2E_COMPANY_NAME=E2E Company
E2E_ADMIN_EMAIL=e2e.admin@tortoise.local
E2E_ADMIN_PASSWORD=e2e-password
E2E_ADMIN_LANGUAGE=en
E2E_TRACKER_SERIAL=9900111001
E2E_TRACKER_ALIAS=E2E Truck 01
DEMO_EMAIL=livedemo@example.com
DEMO_PASSWORD=LiveDemo

# ── track-tcp ─────────────────────────────────────────────────────────────────
TCP_PORT=5000
API_URL=http://localhost:8080/api

# ── tracker-simulator ──────────────────────────────────────────────────────────
TCP_HOST=127.0.0.1
SIM_STATE_FILE=/tmp/tortoise-sim-state.json
SIM_HEARTBEAT_FILE=/tmp/tortoise-sim-heartbeat

# ── track-app (build-time — baked into Vite bundle) ───────────────────────────
# Local dev: leave as /api (Vite proxy)
# Production: set to https://api.yourdomain.com/api
VITE_API_URL=/api

# ── codegen (CI override) ─────────────────────────────────────────────────────
# GRAPHQL_SCHEMA_URL=https://api.yourdomain.com/graphql
