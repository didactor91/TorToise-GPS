# tracker-simulator environment template — copy to .env and fill in values

# TCP server host (track-tcp server)
TCP_HOST=127.0.0.1

# TCP server port
TCP_PORT=5000

# track-api REST base URL (used by setup.js)
API_URL=http://localhost:8085/api

# Optional persistence files
SIM_STATE_FILE=/tmp/tortoise-sim-state.json
SIM_HEARTBEAT_FILE=/tmp/tortoise-sim-heartbeat
