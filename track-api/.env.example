# track-api environment template
# Copy this file to .env and fill in real values — NEVER commit .env

# Server port
PORT=8080

# MongoDB connection string
MONGO_URL=mongodb://localhost:27017/tortoise-gps

# JWT signing secret — use a long random string in production
# Generate one with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_a_long_random_secret
DEFAULT_COMPANY_NAME=Default Company
DEFAULT_COMPANY_SLUG=default-company
FORCE_SINGLE_COMPANY=false

# Simulator track retention cleanup (track-api)
SIM_TRACK_CLEANUP_ENABLED=true
SIM_TRACK_RETENTION_DAYS=60
SIM_TRACK_CLEANUP_INTERVAL_MINUTES=60
SIM_TRACK_CLEANUP_INITIAL_DELAY_MINUTES=2
SIM_TRACK_SERIALS=9900111001,9900111002,9900111003,9900111004,9900111005,9900111006,9900111007,9900111008,9900111009,9900111010,9900111011,9900111012,9900111013,9900111014,9900111015,9900111016,9900111017,9900111018,9900111019,9900111020,9900111021,9900111022,9900111023,9900111024,9900111025,9900111026,9900111027,9900111028,9900111029,9900111030

# Test database URLs (used by vitest only — safe to leave as localhost)
MONGO_URL_LOGIC_TEST=mongodb://localhost:27017/track-api-test
MONGO_URL_USER_DATA_TEST=mongodb://localhost:27017/track-api-user-data-test
