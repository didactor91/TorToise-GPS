# track-api environment template
# Copy this file to .env and fill in real values — NEVER commit .env

# Server port
PORT=8080

# MongoDB connection string
MONGO_URL=mongodb://localhost:27017/tortoise-gps

# JWT signing secret — use a long random string in production
# Generate one with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_a_long_random_secret

# Test database URLs (used by vitest only — safe to leave as localhost)
MONGO_URL_LOGIC_TEST=mongodb://localhost:27017/track-api-test
MONGO_URL_USER_DATA_TEST=mongodb://localhost:27017/track-api-user-data-test
