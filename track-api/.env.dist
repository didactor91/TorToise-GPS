# track-api environment template — copy to .env and fill in values

PORT=8080
JWT_SECRET=change-me-in-production
MONGO_URL=mongodb://localhost:27017/tortoise-gps
SIM_TRACK_CLEANUP_ENABLED=true
SIM_TRACK_RETENTION_DAYS=60
SIM_TRACK_CLEANUP_INTERVAL_MINUTES=60
SIM_TRACK_CLEANUP_INITIAL_DELAY_MINUTES=2
SIM_TRACK_SERIALS=9900110011,9900110012,9900110013,9900110014
MONGO_URL_LOGIC_TEST=mongodb://localhost:27017/track-api-test
